{
  "name": "guru-ai-platform",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "mobile",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "clean": "npm run clean:web && npm run clean:api",
    "clean:web": "rimraf frontend/.next frontend/node_modules",
    "clean:api": "rimraf backend/node_modules",
    "kill": "taskkill /F /IM node.exe /T || exit 0",
    "fix": "npm run kill && npm run clean && npm install --legacy-peer-deps",
    "dev": "concurrently -k \"npm run dev:web\" \"npm run dev:api\" \"npm run dev:ai\"",
    "dev:web": "npm --prefix frontend run dev",
    "dev:api": "npm --prefix backend run dev",
    "dev:ai": "python -m uvicorn ai-service.main:app --host 0.0.0.0 --port 8000",
    "dev:infra": "docker compose up -d postgres redis",
    "build": "npm run build:web && npm run build:api",
    "build:web": "npm --prefix frontend run build",
    "build:api": "npm --prefix backend run build",
    "typecheck": "npm run typecheck:api",
    "typecheck:api": "npm --prefix backend run typecheck",
    "db:migrate": "psql %DATABASE_URL% -f packages/database/migrations/001_init.sql",
    "db:seed": "psql %DATABASE_URL% -f packages/database/seeds/dev.sql",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down -v"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
